class Solution {
    public static int kthLargest(int arr[], int k) {
        // code here
        PriorityQueue<Integer> pq = new PriorityQueue<>(Collections.reverseOrder());
        
        for(int i=0; i<arr.length; i++){
            pq.add(arr[i]);
        }
        
        
        for(int i=0; i<k-1; i++){
            pq.remove();
        }
        
        return pq.peek();
        
    }
}
